%% ============================================================
%%  DESIGN: academic-article
%%  A clean A4 academic paper style.
%%  Usage: \usepackage{../../designs/academic-article/design}
%%         (adjust the relative path from your paper's main.tex)
%% ============================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{design}[2024/01/01 Academic Article Design]

%% --- Language & Encoding -----------------------------------
\RequirePackage[english]{babel}
\RequirePackage[utf8x]{inputenc}
\RequirePackage[T1]{fontenc}
%% Package for flow diagrams
\RequirePackage{tikz}
\usetikzlibrary{arrows.meta, positioning, shapes, calc}  % common 

%% --- Page Layout -------------------------------------------
\RequirePackage[a4paper,
                top=3cm, bottom=2cm,
                left=3cm, right=3cm,
                marginparwidth=1.75cm]{geometry}

%% --- Tables ------------------------------------------------
\RequirePackage{booktabs}
\RequirePackage{tabu}

%% --- Math --------------------------------------------------
\RequirePackage{amsmath}

%% --- Figures -----------------------------------------------
\RequirePackage{graphicx}
\RequirePackage{float}

%% --- Annotations -------------------------------------------
\RequirePackage[colorinlistoftodos]{todonotes}

%% --- Hyperlinks --------------------------------------------
\RequirePackage[colorlinks=true, allcolors=blue]{hyperref}
